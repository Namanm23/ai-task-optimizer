# .env.example
# Copy this file to .env and fill in your values
# Never commit .env to GitHub!

# ngrok auth token
# Get from: https://dashboard.ngrok.com/authtokens
NGROK_TOKEN=your_ngrok_token_here

# Optional: ngrok static domain
# Get from: https://dashboard.ngrok.com/domains
# NGROK_DOMAIN=your-static-domain.ngrok-free.app

# API settings (optional overrides)
# API_PORT=8000
